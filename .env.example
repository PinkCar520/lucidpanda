# LucidPanda Environment Variables
# Copy to .env and fill in actual values.
# NEVER commit .env to Git.

# ============================================
# 1. Runtime Mode
# ============================================
SIMULATION_MODE=false
CHECK_INTERVAL_MINUTES=2

# ============================================
# 2. LLM Providers
# ============================================
# 主力 AI Provider: 'qwen', 'deepseek', 'gemini'
AI_PROVIDER=qwen

# Qwen (阿里云百炼) - 推荐（国内稳定，免费额度 100 万 tokens）
# 获取 API Key: https://bailian.console.aliyun.com/
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen3.5-flash
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Gemini（备选，需要代理）
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BATCH_MODEL=gemini-2.0-flash-lite

# DeepSeek（备选/降级）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ============================================
# 3. Database
# ============================================
DB_TYPE=postgres
DB_PATH=LucidPanda.db

POSTGRES_USER=LucidPanda
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=LucidPanda_core
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ============================================
# 4. Redis / Cache
# ============================================
REDIS_URL=redis://localhost:6379/0
FUSED_CACHE_USE_REDIS=true

# ============================================
# 5. RSSHub / Feeds
# ============================================
RSSHUB_BASE_URL=https://rsshub.app

# ============================================
# 6. Notifications (Optional)
# ============================================
SMTP_SERVER=your_smtp_host
SMTP_PORT=587
EMAIL_SENDER=your_email@example.com
EMAIL_PASSWORD=your_email_app_password
EMAIL_RECEIVER=recipient@example.com
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_123456789abc
BARK_URL=https://api.day.app/your_device_key

# ============================================
# 7. Web / URLs
# ============================================
FRONTEND_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8001/api
API_INTERNAL_URL=http://api:8001
AUTH_URL=http://localhost:3000

# ============================================
# 8. Auth / Security
# ============================================
AUTH_SECRET=your_nextauth_secret_key
API_KEY=
SECRET_KEY=your_backend_jwt_secret
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

RISK_DEVICE_MISMATCH_FORCE_REAUTH=true
RISK_IP_CHANGE_FORCE_REAUTH=true
RISK_IP_CHANGE_WINDOW_MINUTES=10

# WebAuthn / Passkeys
RP_ID=localhost
RP_NAME=LucidPanda
ORIGIN=http://localhost:3000

# ============================================
# 9. Observability / Logging
# ============================================
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
LOG_FORMAT=text

# ============================================
# 10. Optional Tuning
# ============================================
# 去重配置已移动到 .env.ai

# ============================================
# 11. Runtime Configuration
# ============================================
# LLM 并发限制（同时进行的 API 调用数）
# 推荐值：4 核 4G=5, 8 核 8G=10, 16 核 16G=20
LLM_CONCURRENCY_LIMIT=5

# Agent 工具配置
AGENT_TOOL_MAX_CALLS=3
AGENT_TOOL_TIMEOUT_SECONDS=8

# ============================================
# 12. Embedding / Vector Search
# ============================================
# 配置已移动到 .env.ai
