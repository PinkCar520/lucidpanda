# LucidPanda AI Configuration
# 所有 AI 模型配置（LLM + Embedding）
# 
# 使用说明：
# 1. 本文件包含所有 AI 相关配置（LLM 大语言模型 + Embedding 文本向量化）
# 2. 与 .env 分离，便于独立管理和部署
# 3. Docker 部署时会自动加载此文件

# =============================================================================
# 1. LLM 配置（大语言模型 - 新闻分析/投资信号提取）
# =============================================================================

# 主力 AI Provider，可选值：'qwen', 'deepseek', 'gemini'
# - qwen: 阿里云百炼（推荐，国内稳定，免费 100 万 tokens）
# - deepseek: 深度求索（中文优化，性价比高）
# - gemini: Google Gemini（需要代理，有每日限额）
AI_PROVIDER=gemini

# ---------------------------------
# Qwen (阿里云百炼) - 推荐主力
# ---------------------------------
# 获取 API Key: https://bailian.console.aliyun.com/
# 免费额度：100 万 tokens（至 2026/06/20）
# 模型选择：qwen3.5-flash（实时分析）/ qwen3.5-plus（复杂任务）
# 特点：延迟 <100ms，中文理解优秀，成本 ¥0.2-1.2/1M tokens
QWEN_API_KEY=sk-dc6de0bad93c46098d07503b071e9311
QWEN_MODEL=qwen3.5-flash
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---------------------------------
# Gemini（备选，需要代理）
# ---------------------------------
# 获取 API Key: https://makersuite.google.com/app/apikey
# 模型说明：
# - GEMINI_MODEL: 实时分析主力（gemini-2.5-flash，1K RPM / 10K RPD）
# - GEMINI_BATCH_MODEL: 批量/回填任务（gemini-2.0-flash-lite，无每日上限）
# - GEMINI_EMBEDDING_MODEL: Embedding 专用（需要代理，国内不推荐）
# 注意：国内访问需要配置 HTTP_PROXY/HTTPS_PROXY
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BATCH_MODEL=gemini-2.0-flash-lite
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# ---------------------------------
# DeepSeek（备选/降级）
# ---------------------------------
# 获取 API Key: https://platform.deepseek.com/
# 模型：deepseek-chat（V3 版本，67B 参数）/ deepseek-reasoner（R1 推理版）
# 特点：中文优化好，成本 ¥1/1M tokens，国内直连
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---------------------------------
# OpenAI（未启用）
# ---------------------------------
# 获取 API Key: https://platform.openai.com/api-keys
# 模型：gpt-4o / gpt-4-turbo / gpt-3.5-turbo
# 注意：需要海外网络环境
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o


# =============================================================================
# 3. 运行时配置
# =============================================================================

# LLM 并发限制：同时进行的 LLM API 调用数量
# 说明：
# - 太小：影响处理速度
# - 太大：可能触发 API 限流或占用过多内存
# 推荐值：
# - 4 核 4G 服务器：3-5
# - 8 核 8G 服务器：5-10
# - 16 核 16G 服务器：10-20
LLM_CONCURRENCY_LIMIT=5

# LLM 降级顺序：当主力 API 失败时的备用顺序
# 格式：逗号分隔的提供商列表
# 可选值：qwen, deepseek, gemini
# 说明：
# - 列表中的第一个作为主力（如果 AI_PROVIDER 未设置）
# - 后面的依次作为备用
# 示例：
# - "qwen,deepseek,gemini": Qwen 主力，DeepSeek 第一备用，Gemini 第二备用
# - "deepseek,qwen": DeepSeek 主力，Qwen 备用
LLM_FALLBACK_ORDER=qwen,deepseek,gemini

# Agent 工具配置
# - 最大调用次数：每次分析最多调用工具次数
# - 超时时间：工具调用超时（秒）
AGENT_TOOL_MAX_CALLS=3
AGENT_TOOL_TIMEOUT_SECONDS=8


# =============================================================================
# 2. Embedding 配置（文本向量化 - 新闻去重/语义搜索）
# =============================================================================

# Embedding Provider，可选值：'dashscope', 'gemini', 'local'
# - dashscope: 阿里云通义千问（推荐，国内稳定）
# - gemini: Google Gemini（需要代理）
# - local: 本地 SentenceTransformer（无需 API，占用内存~1.5GB）
EMBEDDING_PROVIDER=dashscope

# ---------------------------------
# DashScope (阿里云通义千问) - 推荐
# ---------------------------------
# 获取 API Key: https://bailian.console.aliyun.com/
# 模型说明：
# - text-embedding-v3: 最新一代，支持弹性维度 1024/768/512/256/128/64（推荐）
# - text-embedding-v2: 性价比高，1536 维固定
# - text-embedding-v1: 基础版，1536 维
# 维度说明：
# - 768: 兼容现有数据库 schema (vector(768))
# - 1024: v3 默认维度，性能最佳
# 免费额度：50 万 tokens（至 2026/06/20）
DASHSCOPE_API_KEY=sk-dc6de0bad93c46098d07503b071e9311
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
DASHSCOPE_EMBEDDING_DIMENSIONS=768

# 启用语义去重（设为 false 仅使用 SimHash）
# 语义去重：基于向量余弦相似度，更准确但消耗更多资源
# SimHash：基于哈希，快速但精度较低
ENABLE_SEMANTIC_DEDUPE=true

# 语义去重参数
# - NEWS_SIMILARITY_THRESHOLD: 余弦相似度阈值（>0.7 认为相似，范围 0-1）
# - NEWS_DEDUPE_WINDOW_HOURS: 去重时间窗口（检查过去 N 小时内的新闻）
NEWS_SIMILARITY_THRESHOLD=0.7
NEWS_DEDUPE_WINDOW_HOURS=24
