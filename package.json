{
  "name": "lucidpanda-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "api:dev": "pnpm --filter api run dev",
    "web:dev": "pnpm --filter web run dev",
    "generate-api": "pnpm --filter schema run generate"
  },
  "devDependencies": {
    "pnpm": "latest"
  }
}
