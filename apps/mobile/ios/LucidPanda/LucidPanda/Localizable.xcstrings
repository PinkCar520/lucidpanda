    "settings.two_factor.hint_description": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, you'll need to provide a 6-digit dynamic verification code from an authenticator app (such as Google Authenticator) in addition to your password each time you log in, effectively preventing account theft."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u542f\u7528\u540e\uff0c\u6bcf\u6b21\u767b\u5f55\u9664\u5bc6\u7801\u5916\u8fd8\u9700\u63d0\u4f9b\u9a8c\u8bc1\u5668 App\uff08\u5982 Google Authenticator\uff09\u751f\u6210\u7684 6 \u4f4d\u52a8\u6001\u9a8c\u8bc1\u7801\uff0c\u6709\u6548\u9632\u6b62\u8d26\u53f7\u88ab\u76d7\u3002"
